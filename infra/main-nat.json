{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.41.2.15936",
      "templateHash": "7499462732315747751"
    }
  },
  "parameters": {
    "adminUsername": {
      "type": "string",
      "defaultValue": "labadmin",
      "metadata": {
        "description": "管理者ユーザー名"
      }
    },
    "adminPassword": {
      "type": "securestring",
      "metadata": {
        "description": "管理者パスワード"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "リソースの場所"
      }
    },
    "domainName": {
      "type": "string",
      "defaultValue": "lab.local",
      "metadata": {
        "description": "Active Directory ドメイン名"
      }
    },
    "vpnSharedKey": {
      "type": "securestring",
      "metadata": {
        "description": "VPN 共有キー (S2S 接続用)"
      }
    },
    "remoteGatewayIp": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "接続先 Azure VPN Gateway のパブリック IP アドレス (空の場合 S2S 接続リソースはスキップ)"
      }
    },
    "remoteAddressPrefix": {
      "type": "string",
      "defaultValue": "10.100.0.0/16",
      "metadata": {
        "description": "接続先 Azure 側のアドレス空間"
      }
    }
  },
  "variables": {
    "dcTags": {
      "Role": "DomainController"
    },
    "dbTags": {
      "Role": "Database"
    },
    "webTags": {
      "Role": "WebServer"
    },
    "sharedTags": {
      "Role": "Shared"
    }
  },
  "resources": [
    {
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2024-05-01",
      "name": "OnPrem-Server-NSG",
      "location": "[parameters('location')]",
      "tags": "[variables('sharedTags')]",
      "properties": {
        "securityRules": [
          {
            "name": "AllowVNetInbound",
            "properties": {
              "priority": 100,
              "direction": "Inbound",
              "access": "Allow",
              "protocol": "*",
              "sourceAddressPrefix": "VirtualNetwork",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "VirtualNetwork",
              "destinationPortRange": "*"
            }
          },
          {
            "name": "DenyInternetInbound",
            "properties": {
              "priority": 4000,
              "direction": "Inbound",
              "access": "Deny",
              "protocol": "*",
              "sourceAddressPrefix": "Internet",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "*"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2024-05-01",
      "name": "OnPrem-NatGw-PIP",
      "location": "[parameters('location')]",
      "tags": "[variables('sharedTags')]",
      "sku": {
        "name": "Standard"
      },
      "properties": {
        "publicIPAllocationMethod": "Static"
      }
    },
    {
      "type": "Microsoft.Network/natGateways",
      "apiVersion": "2024-05-01",
      "name": "OnPrem-NatGw",
      "location": "[parameters('location')]",
      "tags": "[variables('sharedTags')]",
      "sku": {
        "name": "Standard"
      },
      "properties": {
        "publicIpAddresses": [
          {
            "id": "[resourceId('Microsoft.Network/publicIPAddresses', 'OnPrem-NatGw-PIP')]"
          }
        ],
        "idleTimeoutInMinutes": 4
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/publicIPAddresses', 'OnPrem-NatGw-PIP')]"
      ]
    },
    {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2024-05-01",
      "name": "OnPrem-VNet",
      "location": "[parameters('location')]",
      "tags": "[variables('sharedTags')]",
      "properties": {
        "addressSpace": {
          "addressPrefixes": [
            "10.0.0.0/16"
          ]
        },
        "dhcpOptions": {
          "dnsServers": [
            "10.0.1.4"
          ]
        },
        "subnets": [
          {
            "name": "ServerSubnet",
            "properties": {
              "addressPrefix": "10.0.1.0/24",
              "networkSecurityGroup": {
                "id": "[resourceId('Microsoft.Network/networkSecurityGroups', 'OnPrem-Server-NSG')]"
              },
              "defaultOutboundAccess": false,
              "natGateway": {
                "id": "[resourceId('Microsoft.Network/natGateways', 'OnPrem-NatGw')]"
              }
            }
          },
          {
            "name": "GatewaySubnet",
            "properties": {
              "addressPrefix": "10.0.255.0/27"
            }
          },
          {
            "name": "AzureBastionSubnet",
            "properties": {
              "addressPrefix": "10.0.254.0/26"
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/natGateways', 'OnPrem-NatGw')]",
        "[resourceId('Microsoft.Network/networkSecurityGroups', 'OnPrem-Server-NSG')]"
      ]
    },
    {
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2024-05-01",
      "name": "OnPrem-Bastion-PIP",
      "location": "[parameters('location')]",
      "tags": "[variables('sharedTags')]",
      "sku": {
        "name": "Standard"
      },
      "properties": {
        "publicIPAllocationMethod": "Static"
      }
    },
    {
      "type": "Microsoft.Network/bastionHosts",
      "apiVersion": "2024-05-01",
      "name": "OnPrem-Bastion",
      "location": "[parameters('location')]",
      "tags": "[variables('sharedTags')]",
      "sku": {
        "name": "Basic"
      },
      "properties": {
        "ipConfigurations": [
          {
            "name": "bastionIpConfig",
            "properties": {
              "publicIPAddress": {
                "id": "[resourceId('Microsoft.Network/publicIPAddresses', 'OnPrem-Bastion-PIP')]"
              },
              "subnet": {
                "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', 'OnPrem-VNet', 'AzureBastionSubnet')]"
              }
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/publicIPAddresses', 'OnPrem-Bastion-PIP')]",
        "[resourceId('Microsoft.Network/virtualNetworks', 'OnPrem-VNet')]"
      ]
    },
    {
      "type": "Microsoft.Network/networkInterfaces",
      "apiVersion": "2024-05-01",
      "name": "OnPrem-AD-NIC",
      "location": "[parameters('location')]",
      "tags": "[variables('dcTags')]",
      "properties": {
        "ipConfigurations": [
          {
            "name": "ipconfig1",
            "properties": {
              "subnet": {
                "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', 'OnPrem-VNet', 'ServerSubnet')]"
              },
              "privateIPAllocationMethod": "Static",
              "privateIPAddress": "10.0.1.4"
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/virtualNetworks', 'OnPrem-VNet')]"
      ]
    },
    {
      "type": "Microsoft.Compute/virtualMachines",
      "apiVersion": "2024-07-01",
      "name": "OnPrem-AD",
      "location": "[parameters('location')]",
      "tags": "[variables('dcTags')]",
      "properties": {
        "hardwareProfile": {
          "vmSize": "Standard_B2ms"
        },
        "osProfile": {
          "computerName": "DC01",
          "adminUsername": "[parameters('adminUsername')]",
          "adminPassword": "[parameters('adminPassword')]",
          "windowsConfiguration": {
            "provisionVMAgent": true,
            "enableAutomaticUpdates": true
          }
        },
        "storageProfile": {
          "imageReference": {
            "publisher": "MicrosoftWindowsServer",
            "offer": "WindowsServer",
            "sku": "2022-Datacenter",
            "version": "latest"
          },
          "osDisk": {
            "createOption": "FromImage",
            "managedDisk": {
              "storageAccountType": "StandardSSD_LRS"
            }
          }
        },
        "networkProfile": {
          "networkInterfaces": [
            {
              "id": "[resourceId('Microsoft.Network/networkInterfaces', 'OnPrem-AD-NIC')]"
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkInterfaces', 'OnPrem-AD-NIC')]"
      ]
    },
    {
      "type": "Microsoft.Compute/virtualMachines/extensions",
      "apiVersion": "2024-07-01",
      "name": "[format('{0}/{1}', 'OnPrem-AD', 'ADSetup')]",
      "location": "[parameters('location')]",
      "properties": {
        "publisher": "Microsoft.Compute",
        "type": "CustomScriptExtension",
        "typeHandlerVersion": "1.10",
        "autoUpgradeMinorVersion": true,
        "protectedSettings": {
          "commandToExecute": "[format('powershell -ExecutionPolicy Unrestricted -Command \"Install-WindowsFeature -Name AD-Domain-Services,DNS -IncludeManagementTools; Import-Module ADDSDeployment; Install-ADDSForest -DomainName {0} -SafeModeAdministratorPassword (ConvertTo-SecureString ''{1}'' -AsPlainText -Force) -DomainNetbiosName ''LAB'' -InstallDNS -Force -NoRebootOnCompletion; shutdown /r /t 60\"', parameters('domainName'), parameters('adminPassword'))]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Compute/virtualMachines', 'OnPrem-AD')]"
      ]
    },
    {
      "type": "Microsoft.Network/networkInterfaces",
      "apiVersion": "2024-05-01",
      "name": "OnPrem-SQL-NIC",
      "location": "[parameters('location')]",
      "tags": "[variables('dbTags')]",
      "properties": {
        "ipConfigurations": [
          {
            "name": "ipconfig1",
            "properties": {
              "subnet": {
                "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', 'OnPrem-VNet', 'ServerSubnet')]"
              },
              "privateIPAllocationMethod": "Static",
              "privateIPAddress": "10.0.1.5"
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/virtualNetworks', 'OnPrem-VNet')]"
      ]
    },
    {
      "type": "Microsoft.Compute/virtualMachines",
      "apiVersion": "2024-07-01",
      "name": "OnPrem-SQL",
      "location": "[parameters('location')]",
      "tags": "[variables('dbTags')]",
      "properties": {
        "hardwareProfile": {
          "vmSize": "Standard_B2ms"
        },
        "osProfile": {
          "computerName": "DB01",
          "adminUsername": "[parameters('adminUsername')]",
          "adminPassword": "[parameters('adminPassword')]",
          "windowsConfiguration": {
            "provisionVMAgent": true,
            "enableAutomaticUpdates": true
          }
        },
        "storageProfile": {
          "imageReference": {
            "publisher": "MicrosoftSQLServer",
            "offer": "sql2022-ws2022",
            "sku": "sqldev-gen2",
            "version": "latest"
          },
          "osDisk": {
            "createOption": "FromImage",
            "managedDisk": {
              "storageAccountType": "StandardSSD_LRS"
            }
          },
          "dataDisks": [
            {
              "lun": 0,
              "diskSizeGB": 128,
              "createOption": "Empty",
              "managedDisk": {
                "storageAccountType": "StandardSSD_LRS"
              }
            }
          ]
        },
        "networkProfile": {
          "networkInterfaces": [
            {
              "id": "[resourceId('Microsoft.Network/networkInterfaces', 'OnPrem-SQL-NIC')]"
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkInterfaces', 'OnPrem-SQL-NIC')]"
      ]
    },
    {
      "type": "Microsoft.SqlVirtualMachine/sqlVirtualMachines",
      "apiVersion": "2023-10-01",
      "name": "OnPrem-SQL",
      "location": "[parameters('location')]",
      "tags": "[variables('dbTags')]",
      "properties": {
        "virtualMachineResourceId": "[resourceId('Microsoft.Compute/virtualMachines', 'OnPrem-SQL')]",
        "sqlServerLicenseType": "PAYG",
        "storageConfigurationSettings": {
          "diskConfigurationType": "NEW",
          "sqlDataSettings": {
            "luns": [
              0
            ],
            "defaultFilePath": "F:\\SQLData"
          },
          "sqlLogSettings": {
            "luns": [
              0
            ],
            "defaultFilePath": "F:\\SQLLog"
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Compute/virtualMachines', 'OnPrem-SQL')]"
      ]
    },
    {
      "type": "Microsoft.Compute/virtualMachines/extensions",
      "apiVersion": "2024-07-01",
      "name": "[format('{0}/{1}', 'OnPrem-SQL', 'DomainJoin')]",
      "location": "[parameters('location')]",
      "properties": {
        "publisher": "Microsoft.Compute",
        "type": "JsonADDomainExtension",
        "typeHandlerVersion": "1.3",
        "autoUpgradeMinorVersion": true,
        "settings": {
          "Name": "[parameters('domainName')]",
          "User": "[format('{0}\\{1}', parameters('domainName'), parameters('adminUsername'))]",
          "Restart": "true",
          "Options": "3"
        },
        "protectedSettings": {
          "Password": "[parameters('adminPassword')]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Compute/virtualMachines/extensions', 'OnPrem-AD', 'ADSetup')]",
        "[resourceId('Microsoft.Compute/virtualMachines', 'OnPrem-SQL')]"
      ]
    },
    {
      "type": "Microsoft.Network/networkInterfaces",
      "apiVersion": "2024-05-01",
      "name": "OnPrem-Web-NIC",
      "location": "[parameters('location')]",
      "tags": "[variables('webTags')]",
      "properties": {
        "ipConfigurations": [
          {
            "name": "ipconfig1",
            "properties": {
              "subnet": {
                "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', 'OnPrem-VNet', 'ServerSubnet')]"
              },
              "privateIPAllocationMethod": "Static",
              "privateIPAddress": "10.0.1.6"
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/virtualNetworks', 'OnPrem-VNet')]"
      ]
    },
    {
      "type": "Microsoft.Compute/virtualMachines",
      "apiVersion": "2024-07-01",
      "name": "OnPrem-Web",
      "location": "[parameters('location')]",
      "tags": "[variables('webTags')]",
      "properties": {
        "hardwareProfile": {
          "vmSize": "Standard_B2ms"
        },
        "osProfile": {
          "computerName": "APP01",
          "adminUsername": "[parameters('adminUsername')]",
          "adminPassword": "[parameters('adminPassword')]",
          "windowsConfiguration": {
            "provisionVMAgent": true,
            "enableAutomaticUpdates": true
          }
        },
        "storageProfile": {
          "imageReference": {
            "publisher": "MicrosoftWindowsServer",
            "offer": "WindowsServer",
            "sku": "2022-Datacenter",
            "version": "latest"
          },
          "osDisk": {
            "createOption": "FromImage",
            "managedDisk": {
              "storageAccountType": "StandardSSD_LRS"
            }
          }
        },
        "networkProfile": {
          "networkInterfaces": [
            {
              "id": "[resourceId('Microsoft.Network/networkInterfaces', 'OnPrem-Web-NIC')]"
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkInterfaces', 'OnPrem-Web-NIC')]"
      ]
    },
    {
      "type": "Microsoft.Compute/virtualMachines/extensions",
      "apiVersion": "2024-07-01",
      "name": "[format('{0}/{1}', 'OnPrem-Web', 'IISSetup')]",
      "location": "[parameters('location')]",
      "properties": {
        "publisher": "Microsoft.Compute",
        "type": "CustomScriptExtension",
        "typeHandlerVersion": "1.10",
        "autoUpgradeMinorVersion": true,
        "settings": {
          "commandToExecute": "powershell -ExecutionPolicy Unrestricted -Command \"Install-WindowsFeature -Name Web-Server,Web-Asp-Net45,Web-Mgmt-Tools,NET-Framework-45-ASPNET -IncludeManagementTools\""
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Compute/virtualMachines', 'OnPrem-Web')]"
      ]
    },
    {
      "type": "Microsoft.Compute/virtualMachines/extensions",
      "apiVersion": "2024-07-01",
      "name": "[format('{0}/{1}', 'OnPrem-Web', 'DomainJoin')]",
      "location": "[parameters('location')]",
      "properties": {
        "publisher": "Microsoft.Compute",
        "type": "JsonADDomainExtension",
        "typeHandlerVersion": "1.3",
        "autoUpgradeMinorVersion": true,
        "settings": {
          "Name": "[parameters('domainName')]",
          "User": "[format('{0}\\{1}', parameters('domainName'), parameters('adminUsername'))]",
          "Restart": "true",
          "Options": "3"
        },
        "protectedSettings": {
          "Password": "[parameters('adminPassword')]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Compute/virtualMachines/extensions', 'OnPrem-AD', 'ADSetup')]",
        "[resourceId('Microsoft.Compute/virtualMachines/extensions', 'OnPrem-Web', 'IISSetup')]",
        "[resourceId('Microsoft.Compute/virtualMachines', 'OnPrem-Web')]"
      ]
    },
    {
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2024-05-01",
      "name": "OnPrem-VpnGw-PIP",
      "location": "[parameters('location')]",
      "tags": "[variables('sharedTags')]",
      "sku": {
        "name": "Standard"
      },
      "properties": {
        "publicIPAllocationMethod": "Static"
      }
    },
    {
      "type": "Microsoft.Network/virtualNetworkGateways",
      "apiVersion": "2024-05-01",
      "name": "OnPrem-VpnGw",
      "location": "[parameters('location')]",
      "tags": "[variables('sharedTags')]",
      "properties": {
        "gatewayType": "Vpn",
        "vpnType": "RouteBased",
        "sku": {
          "name": "VpnGw1",
          "tier": "VpnGw1"
        },
        "ipConfigurations": [
          {
            "name": "vpnGwIpConfig",
            "properties": {
              "publicIPAddress": {
                "id": "[resourceId('Microsoft.Network/publicIPAddresses', 'OnPrem-VpnGw-PIP')]"
              },
              "subnet": {
                "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', 'OnPrem-VNet', 'GatewaySubnet')]"
              }
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/virtualNetworks', 'OnPrem-VNet')]",
        "[resourceId('Microsoft.Network/publicIPAddresses', 'OnPrem-VpnGw-PIP')]"
      ]
    },
    {
      "condition": "[not(equals(parameters('remoteGatewayIp'), ''))]",
      "type": "Microsoft.Network/localNetworkGateways",
      "apiVersion": "2024-05-01",
      "name": "Azure-LocalGw",
      "location": "[parameters('location')]",
      "tags": "[variables('sharedTags')]",
      "properties": {
        "gatewayIpAddress": "[parameters('remoteGatewayIp')]",
        "localNetworkAddressSpace": {
          "addressPrefixes": [
            "[parameters('remoteAddressPrefix')]"
          ]
        }
      }
    },
    {
      "condition": "[not(equals(parameters('remoteGatewayIp'), ''))]",
      "type": "Microsoft.Network/connections",
      "apiVersion": "2024-05-01",
      "name": "OnPrem-to-Azure-S2S",
      "location": "[parameters('location')]",
      "tags": "[variables('sharedTags')]",
      "properties": {
        "connectionType": "IPsec",
        "virtualNetworkGateway1": {
          "id": "[resourceId('Microsoft.Network/virtualNetworkGateways', 'OnPrem-VpnGw')]",
          "properties": {}
        },
        "localNetworkGateway2": {
          "id": "[resourceId('Microsoft.Network/localNetworkGateways', 'Azure-LocalGw')]",
          "properties": {}
        },
        "sharedKey": "[parameters('vpnSharedKey')]",
        "connectionProtocol": "IKEv2"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/localNetworkGateways', 'Azure-LocalGw')]",
        "[resourceId('Microsoft.Network/virtualNetworkGateways', 'OnPrem-VpnGw')]"
      ]
    }
  ],
  "outputs": {
    "vpnGatewayPublicIp": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Network/publicIPAddresses', 'OnPrem-VpnGw-PIP'), '2024-05-01').ipAddress]"
    },
    "bastionName": {
      "type": "string",
      "value": "OnPrem-Bastion"
    },
    "natGatewayPublicIp": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Network/publicIPAddresses', 'OnPrem-NatGw-PIP'), '2024-05-01').ipAddress]"
    },
    "adServerPrivateIp": {
      "type": "string",
      "value": "10.0.1.4"
    },
    "sqlServerPrivateIp": {
      "type": "string",
      "value": "10.0.1.5"
    },
    "webServerPrivateIp": {
      "type": "string",
      "value": "10.0.1.6"
    }
  }
}